#!/usr/bin/env bash
#!/usr/bin/env bash

# Prospector IA Botz - Launcher Principal

BASE_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
cd "$BASE_DIR"

# Verificar venv
if [ ! -d "venv" ]; then
    echo "⚠️  Ambiente virtual não encontrado. Rode: ./install.sh"
    exit 1
fi

source venv/bin/activate

# Comandos
case "${1:-menu}" in
    menu|"")
        python3 menu-guiado.py
        ;;
    setup)
        python3 menu-guiado.py
        ;;
    prospectar)
        shift
        python3 skills/prospeccao-playwright/references/scraper-playwright.py "$@"
        ;;
    redesenhar)
        shift
        python3 skills/redesign-premium/references/redesign.py "$@"
        ;;
    publicar)
        shift
        python3 skills/deploy-aapanel/references/deploy.py "$@"
        ;;
    proposta)
        shift
        python3 skills/proposta-email/references/proposta.py "$@"
        ;;
    proposta-whatsapp)
        shift
        python3 skills/proposta-whatsapp/references/proposta_whatsapp.py "$@"
        ;;
    followup)
        shift
        python3 skills/proposta-email/references/followup.py "$@"
        ;;
    followup-whatsapp)
        shift
        python3 skills/proposta-whatsapp/references/followup_whatsapp.py "$@"
        ;;
    respostas)
        shift
        python3 scripts/check_responses.py "${1:-todos}"
        ;;
    dashboard)
        exec gunicorn -b 127.0.0.1:8765 -w 2 --timeout 120 wsgi:app
        ;;
    test-aapanel)
        python3 -c "
import sys
sys.path.insert(0, 'skills/deploy-aapanel/references')
from aapanel_api import AAPanelClient
import json
with open('prospector-config.json') as f:
    c = json.load(f)['aapanel']
client = AAPanelClient(c['url'], c['api_token'])
print('API:', 'OK' if client.test_connection() else 'FALHOU')
sites = client.list_sites()
print(f'Sites: {len(sites)}')
for s in sites[:5]:
    print(f'  - {s.get(\"domain\")} ({s.get(\"path\")})')
"
        ;;
    test-playwright)
        python3 -c "
from playwright.async_api import async_playwright
import asyncio
async def test():
    async with async_playwright() as p:
        browser = await p.chromium.launch(headless=True)
        page = await browser.new_page()
        await page.goto('https://example.com')
        print('Título:', await page.title())
        await browser.close()
        print('✅ Playwright OK!')
asyncio.run(test())
"
        ;;
    test-sftp)
        python3 -c "
import paramiko, json
with open('prospector-config.json') as f:
    c = json.load(f)['aapanel']
host = c['url'].replace('https://','').replace('http://','')
user = c['usuario']
pwd = c['senha']
print(f'Testando SFTP: {user}@{host}')
try:
    transport = paramiko.Transport((host, 22))
    transport.connect(username=user, password=pwd)
    sftp = paramiko.SFTPClient.from_transport(transport)
    print('✅ SFTP conectado!')
    sftp.listdir('.')
    sftp.close()
    transport.close()
except Exception as e:
    print(f'❌ Falha: {e}')
"
        ;;
    install)
        ./install.sh
        ;;
    update)
        git pull
        ./install.sh
        ;;
    logs)
        latest="$(find logs -maxdepth 1 -type f -name '*.log' -printf '%T@ %p\n' 2>/dev/null | sort -nr | head -1 | cut -d' ' -f2-)"
        [ -n "$latest" ] && tail -f "$latest" || echo "Log não encontrado"
        ;;
    clean)
        rm -f playwright-state.json
        echo "Cache limpo"
        ;;
    help|--help|-h)
        cat << 'EOF'
═══════════════════════════════════════════════════════════════
   🤖 PROSPECTOR IA BOTZ - Comandos
═══════════════════════════════════════════════════════════════

MENU INTERATIVO:
  ./prospector              # Menu guiado principal (recomendado)
  ./prospector setup        # Configuração inicial guiada

COMANDOS DIRETOS:
  ./prospector prospectar [nicho] [cidade] [--meta N]
                          # Prospecção Playwright (Google Maps)
  ./prospector redesenhar [slug|todos]
                          # Redesign de sites
  ./prospector publicar [slug|todos]
                          # Deploy no aapanel (SSL automático)
  ./prospector proposta [slug|todos]
                          # Gerar rascunhos de proposta no Gmail
  ./prospector proposta-whatsapp [slug|todos]
                          # Enviar proposta via WhatsApp (Evolution)
  ./prospector followup     # Follow-up leads sem resposta (3+ dias)
  ./prospector followup-whatsapp [slug|todos]
                          # Follow-up via WhatsApp
  ./prospector respostas [slug|todos]
                          # Detectar envios e respostas no Gmail
  ./prospector dashboard    # Iniciar painel Flask

TESTES E DIAGNÓSTICO:
  ./prospector test-aapanel   # Testar conexão API aapanel
  ./prospector test-playwright # Testar Playwright/Chromium
  ./prospector test-sftp      # Testar SFTP/SSH servidor
  ./prospector logs          # Ver log mais recente
  ./prospector clean         # Limpar cache local

MANUTENÇÃO:
  ./prospector install      # Reinstalar dependências
  ./prospector update       # Atualizar repo + reinstalar

EXEMPLOS:
  ./prospector prospectar nutricionistas "São Paulo" --meta 10
  ./prospector prospectar dentistas "Rio de Janeiro" --meta 5
  ./prospector publicar nutricionista-joao-sao-paulo
  ./prospector publicar todos
  ./prospector proposta todos

CONFIGURAÇÃO:
  Edite: prospector-config.json
  - assinatura: nome, apresentação, whatsapp
  - prospeccao: nichos, cidade, leadsPorBusca, filtros
  - playwright: headless, stealth, proxy, delays
  - aapanel: url, api_token, usuario, senha, dominio_base, usar_subpasta
  - deploy_target: "aapanel"

DASHBOARD LOCAL:
  ./iniciar-dashboard.sh      # Inicia em http://localhost:8765
  Requer Python + Flask. Modo edição = banco SQLite.

ARQUIVOS IMPORTANTES:
  prospector-config.json   # Config principal (NUNCA commite senhas!)
  leads.md                 # Backup local dos leads
  prospector.db            # Banco SQLite (dashboard)
  sites/                   # Sites gerados (por slug)
  drafts/                  # Rascunhos locais
  logs/                    # Logs operacionais
  playwright-state.json    # Estado persistente (cookies, login)

DOCUMENTAÇÃO:
  README.md                # Manual público
  skills/*/SKILL.md        # Documentação técnica de cada skill
EOF
        ;;
    *)
        echo "❌ Comando desconhecido: $1"
        echo "Use: ./prospector help"
        exit 1
        ;;
esac
